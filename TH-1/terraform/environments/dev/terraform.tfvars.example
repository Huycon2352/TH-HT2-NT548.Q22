# Environment Variables for Dev Environment
# These values override the defaults in variables.tf

# Change abcd - to your 

aws_region         = "ap-southeast-1"
project_name       = "abcd"
environment        = "dev"
vpc_cidr           = "10.1.0.0/16"
public_subnet_cidr = "10.1.1.0/24"
private_subnet_cidr = "10.1.2.0/24"
availability_zone  = "ap-southeast-1a"
instance_type      = "t3.micro"
ami_id             = "ami-0543dbdaf4e114be7"
key_name           = "abcd-key"

# EC2 SSH Access Configuration
ssh_source_cidr    = ["0.0.0.0/0"]

# VPC DNS Configuration
enable_dns_hostnames    = true
enable_dns_support      = true
map_public_ip_on_launch = true

# Network Configuration
internet_route_cidr = "0.0.0.0/0"
enable_all_egress   = true
egress_cidr_blocks  = ["0.0.0.0/0"]

# EC2 Security Configuration (SSH)
ssh_port     = 22
ssh_protocol = "tcp"

# EC2 Egress Security Configuration
egress_from_port = 0
egress_to_port   = 0
egress_protocol  = "-1"

# VPC Resource Type Tags
public_subnet_type             = "Public"
private_subnet_type            = "Private"

# NAT Gateway Configuration
nat_eip_domain = "vpc"

# EC2 Instance Type Tags
public_instance_type  = "Public"
private_instance_type = "Private"

# Security Group Descriptions (EC2)
public_sg_description        = "Security group for public EC2 instance"
public_sg_ssh_description    = "SSH access"
public_sg_egress_description = "Allow all outbound traffic"
private_sg_description       = "Security group for private EC2 instance"
private_sg_ssh_description   = "SSH from public EC2 instance"
private_sg_egress_description = "Allow all outbound traffic"

